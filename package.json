{
    "name": "design-tokens",
    "version": "3.17.2",
    "description": "Design tokens",
    "author": "",
    "license": "MIT",
    "packageManager": "yarn@4.1.1",
    "keywords": [
        "design-system",
        "design-tokens",
        "style-dictionary",
        "figma",
        "koobiq"
    ],
    "scripts": {
        "stage:commit": "koobiq-cli stage-commit -c \"Design Tokens\"",
        "-----Release-----": "----------------------------------------------------------------------------------------",
        "release:publish:ci-github": "koobiq-cli publish-ci-github",
        "release:publish:ci-gitlab": "koobiq-cli publish-ci-gitlab",
        "-----Lint-----": "------------------------------------------------------------------------------------------",
        "eslint:dist": "eslint --no-eslintrc --env es2020 --no-ignore dist/design-tokens/web/**/*.js",
        "stylelint:dist": "stylelint dist/design-tokens/web/**/*.{css,scss}",
        "lint:all:dist": "yarn run eslint:dist && yarn run stylelint:dist",
        "-----Build-----": "------------------------------------------------------------------------------------------",
        "build": "rimraf dist && node tools/build.js",
        "-----CI-----": "---------------------------------------------------------------------------------------------",
        "prettier": "prettier --check . --ignore-unknown",
        "prettier:fix": "yarn run prettier --write",
        "eslint": "eslint . --ext='.js'",
        "eslint:fix": "yarn run eslint --fix"
    },
    "publishConfig": {
        "access": "public"
    },
    "release": {
        "packages": [
            "design-tokens",
            "tokens-builder"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@koobiq/cli": "^19.5.0",
        "@types/eslint": "^8.56.12",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^24.10.4",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-prettier": "^5.5.5",
        "fs-extra": "^11.3.4",
        "husky": "^9.1.7",
        "lint-staged": "^15.5.2",
        "prettier": "^3.8.1",
        "rimraf": "^5.0.5",
        "style-dictionary": "^3.9.2",
        "stylelint": "^16.26.1",
        "stylelint-config-recommended-scss": "^16.0.2"
    }
}
